{
  "name": "ar-birthday-card",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web 端 AR 互动生日贺卡：MindAR 图像追踪 + React Three Fiber",
  "scripts": {
    "dev": "vite",
    "dev:https": "cross-env HTTPS_SPIKE=1 vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "tsc -b",
    "format": "prettier --write .",
    "gen:cake": "node scripts/gen-cake-glb.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "mind-ar": "1.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.19.20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.11"
  },
  "overrides": {
    "canvas": "npm:@napi-rs/canvas@^0.1.0",
    "three": "$three"
  },
  "engines": {
    "node": ">=18"
  }
}
